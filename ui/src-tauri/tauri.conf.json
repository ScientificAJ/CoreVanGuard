{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CoreVanguard",
  "version": "0.1.0",
  "identifier": "com.corevanguard.console",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "CoreVanguard",
        "label": "main",
        "width": 1600,
        "height": 1100,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}

